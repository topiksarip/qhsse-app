# =============================================================================
# QHSSE App — Environment Example
# Untuk Docker: cp .env.docker .env  lalu docker compose up -d
# Untuk lokal:  cp .env.example .env lalu isi manual
# =============================================================================

APP_NAME="QHSSE App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logging ────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────────
# Lokal (SQLite):
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# Docker (PostgreSQL) — uncomment jika pakai docker compose:
# DB_CONNECTION=pgsql
# DB_HOST=postgres
# DB_PORT=5432
# DB_DATABASE=qhsse
# DB_USERNAME=qhsse
# DB_PASSWORD=secret
# DB_PORT_EXPOSE=5432

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
# Docker: REDIS_HOST=redis, REDIS_PASSWORD=redissecret
# REDIS_PORT_EXPOSE=6379

# ── Session / Cache / Queue ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
# Docker: SESSION_DRIVER=redis, CACHE_STORE=redis, QUEUE_CONNECTION=redis

# ── Filesystem ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@qhsse.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── Vite ────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
